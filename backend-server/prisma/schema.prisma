// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PROVIDER {
  LOCAL
  GOOGLE
  FACEBOOK
  TWITTER
}

enum ICPType {
  BUSINESS
  CREATOR
}

enum PLATFORM {
  TWITTER
  LINKEDIN
  FACEBOOK
  INSTAGRAM
  TIKTOK
}

enum POST_STATUS {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  name         String
  password     String?
  googleId     String?    @unique
  refreshToken String?    @unique
  provider     PROVIDER[]
  avatar       String?
  bio          String?

  icp               ICP?
  posts             Post[]
  connectedAccounts connectedAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ICP {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type ICPType // 👈 NEW

  audienceDescription String // dreamClient / dreamFollower
  painPoint           String? // problem
  desiredOutcome      String? // outcome / feeling
  motivation          String? // followReason
  contentTopic        String? // topic
  backstory           String? // story / backstory
  goal                String? // goal
  demographics        String?
  additional          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model connectedAccount {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  twitterId   String? @unique
  facebookId  String? @unique
  linkedInId  String? @unique
  tiktokId    String? @unique
  instagramId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Post {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  title           String?
  content         String
  hashtags        String[]
  mediaUrls       String[]
  platforms       PLATFORM[]
  platformContent Json?
  externalPostIds Json?
  status          POST_STATUS @default(DRAFT)

  scheduledAt DateTime?
  publishedAt DateTime?

  isDeleted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
